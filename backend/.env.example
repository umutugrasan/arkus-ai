# ════════════════════════════════════════════════════════════════════════
#  Backend .env — ileri seviye tuning. Local docker-compose icin opsiyonel,
#  root .env.example zaten temel ihtiyaclari karsiliyor. Bu dosyadaki her
#  degisken backend/app/config.py icindeki Settings sinifina mapleniyor.
#
#  Production (Cloud Run) icin: bu dosya KULLANILMAZ. deploy.yml GitHub
#  Secrets'tan okur; default'lari override etmek isterseniz deploy.yml'in
#  --set-env-vars listesine secret eklemek gerekir.
# ════════════════════════════════════════════════════════════════════════

# --- Ortam ---
APP_ENV=development        # development | production
LOG_LEVEL=INFO
LOG_FORMAT=json            # json | text

# --- Database ---
DATABASE_URL=postgresql://arkus:arkuspassword@db:5432/arkus_db

# --- Auth / JWT (PRODUCTION'DA MUTLAKA DEGISTIR) ---
JWT_SECRET=change-me-with-openssl-rand-base64-32-or-similar
JWT_ACCESS_TTL_MIN=60
JWT_REFRESH_TTL_DAYS=30

# --- CORS (production: virgulle ayrilmis allowlist) ---
# CORS_ORIGINS=https://arkus.ai,https://app.arkus.ai
CORS_ORIGINS=*

# --- Gemini ---
# Tek-key fallback (tum pool'lara DEFAULT olarak servis edilir).
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- Gemini amac-bazli key havuzu (opsiyonel, onerilen) ---
# Her pool round-robin + 60sn cooldown ile calisir. Bos pool DEFAULT'a duser.
# Demoda chat'in quota'ya takilmamasi icin CHAT pool izole edilmesi onemli.
# Virgulle ayrilmis key listesi:
# GEMINI_API_KEYS_AGENTS=AIza...,AIza...
# GEMINI_API_KEYS_CHAT=AIza...,AIza...
# GEMINI_API_KEYS_ANALYZE=AIza...,AIza...
# GEMINI_API_KEYS_VISION=AIza...
# GEMINI_API_KEYS_DEFAULT=AIza...,AIza...

# --- AliExpress Affiliate API (opsiyonel — olmadan Playwright fallback çalışır) ---
# Kayıt: https://portals.aliexpress.com/ → Publisher → Tools → API Access
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=

# --- Web Scraping (opsiyonel) ---
# SCRAPER_API_KEY tanimliysa production modu: ScraperAPI HTTP render + Playwright
# fallback'leri DEVRE DISI (Chromium ~500MB RAM, Cloud Run'da OOM riski).
# Local'de bos birakilirsa Playwright tam guc calisir.
# Kayit: https://www.scraperapi.com
SCRAPER_API_KEY=

# --- Mock pazaryeri API ---
MOCK_MARKETPLACE_API_URL=http://mock-api:8001

# --- Rate limits (slowapi syntax) ---
RATE_LIMIT_AI_PER_MIN=10/minute
RATE_LIMIT_DEFAULT_PER_MIN=60/minute

# --- Agent thresholds ---
LOW_STOCK_DAYS=15
LOW_STOCK_CRITICAL_DAYS=7
LOW_RATING_THRESHOLD=4.0
LOW_RATING_MIN_REVIEWS=50
COMPETITOR_PRICE_CHANGE_PCT=3.0
COMPETITOR_PRICE_WARNING_PCT=5.0
NEGATIVE_REVIEW_THRESHOLD_PCT=40.0

# --- Agent scheduler (0 = kapali) ---
AGENT_INTERVAL_SECONDS=3600

# --- Upload ---
UPLOAD_DIR=/tmp/arkus_uploads
