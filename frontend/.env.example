# Arkus AI — Frontend Build-time Env (Vite)
#
# Kopyala: cp .env.example .env.local  (dev icin)
#         cp .env.example .env.production  (prod build icin)
#
# Vite yalnizca VITE_ prefix'li degiskenleri istemciye gomer.

# Backend API base URL (path /api/v1 dahil).
# Bos birakirsan:
#   - localhost'ta dev sunucu http://localhost:8000/api/v1 kullanir
#   - diger hostlarda reverse-proxy ile same-origin "/api/v1" kullanir
VITE_API_URL=
