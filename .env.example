# cp .env.example .env  ve degerleri doldur. Production icin GitHub Secrets kullanilir.

# ─── Gemini API Keys ─────────────────────────────────────────────────
# Toplam kapasite: 4500 istek/gun, 45 RPM esleyazaman.

# Legacy tek-key (geriye uyumluluk icin bos, pool'lar dolu)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Otonom ajanlar (Review/Competitor/Sourcing/Response/Report) — 2 key paylasir
GEMINI_API_KEYS_AGENTS=

# AI Chat (arkus_agent) — IZOLE bir key; juri konusurken 429 yiyemez
GEMINI_API_KEYS_CHAT=

# 9 analiz endpoint'i (dashboard, reviews, competitors, financials, vs.) — 3 key round-robin
GEMINI_API_KEYS_ANALYZE=

# Vision (image-analyzer) — nadiren cagrilir
GEMINI_API_KEYS_VISION=

# Default fallback — yukaridaki pool'lar tukenirse buraya duser
GEMINI_API_KEYS_DEFAULT=

# ─── App settings ──────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=text
CORS_ORIGINS=*

# ─── JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=change-me-with-openssl-rand-base64-32-or-similar
JWT_ACCESS_TTL_MIN=60
JWT_REFRESH_TTL_DAYS=30

# ─── Agent scheduler ───────────────────────────────────────────────────
# 0 = kapali (demo sirasinda manuel tetik daha temiz, otomatik quota tuketmez)
AGENT_INTERVAL_SECONDS=0

# ─── Tedarik Avcisi (opsiyonel) ────────────────────────────────────────
# Bos = local'de Playwright fallback calisir; production'da gerekli
SCRAPER_API_KEY=
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=
